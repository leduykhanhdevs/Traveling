{
    "name":  "@traveling/mobile",
    "version":  "1.0.0",
    "private":  true,
    "main":  "expo-router/entry",
    "scripts":  {
                    "android":  "expo start --android",
                    "build":  "expo export --platform web",
                    "dev":  "expo start",
                    "ios":  "expo start --ios",
                    "lint":  "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"services/**/*.{ts,tsx}\" \"stores/**/*.{ts,tsx}\" \"utils/**/*.{ts,tsx}\"",
                    "start":  "expo start",
                    "start:lan":  "powershell -ExecutionPolicy Bypass -File ./scripts/start-lan.ps1",
                    "start:tunnel":  "expo start --tunnel -c",
                    "test":  "jest --config package.json --runInBand",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "web":  "expo start --web"
                },
    "dependencies":  {
                         "@clerk/clerk-expo":  "^2.3.0",
                         "@expo-google-fonts/inter":  "^0.2.3",
                         "@expo/vector-icons":  "^15.0.3",
                         "@react-native-async-storage/async-storage":  "2.2.0",
                         "@react-native-community/netinfo":  "11.4.1",
                         "@sentry/react-native":  "~7.2.0",
                         "@tanstack/query-sync-storage-persister":  "^5.100.14",
                         "@tanstack/react-query":  "^5.56.2",
                         "@traveling/shared":  "1.0.0",
                         "expo":  "~54.0.0",
                         "expo-av":  "~16.0.8",
                         "expo-blur":  "~15.0.8",
                         "expo-build-properties":  "~1.0.10",
                         "expo-camera":  "~17.0.10",
                         "expo-constants":  "~18.0.13",
                         "expo-file-system":  "~19.0.23",
                         "expo-font":  "~14.0.12",
                         "expo-haptics":  "~15.0.8",
                         "expo-image-picker":  "~17.0.11",
                         "expo-linking":  "~8.0.12",
                         "expo-location":  "~19.0.8",
                         "expo-notifications":  "~0.32.17",
                         "expo-print":  "~15.0.8",
                         "expo-router":  "~6.0.24",
                         "expo-secure-store":  "~15.0.8",
                         "expo-sharing":  "~14.0.8",
                         "expo-sms":  "~14.0.8",
                         "expo-speech":  "~14.0.8",
                         "expo-splash-screen":  "~31.0.13",
                         "expo-status-bar":  "~3.0.9",
                         "expo-web-browser":  "~15.0.11",
                         "lottie-react-native":  "~7.3.1",
                         "lucide-react-native":  "^0.441.0",
                         "nativewind":  "4.1.23",
                         "react":  "19.1.0",
                         "react-dom":  "19.1.0",
                         "react-native":  "0.81.5",
                         "react-native-css-interop":  "0.1.22",
                         "react-native-draggable-flatlist":  "^4.0.1",
                         "react-native-gesture-handler":  "~2.28.0",
                         "react-native-maps":  "1.20.1",
                         "react-native-mmkv":  "^2.12.2",
                         "react-native-purchases":  "^8.2.4",
                         "react-native-reanimated":  "~4.1.1",
                         "react-native-safe-area-context":  "~5.6.0",
                         "react-native-screens":  "~4.16.0",
                         "react-native-svg":  "15.12.1",
                         "react-native-web":  "^0.21.0",
                         "zustand":  "^4.5.5"
                     },
    "devDependencies":  {
                            "@types/react":  "~19.1.10",
                            "babel-preset-expo":  "^56.0.14",
                            "jest":  "^29.7.0",
                            "react-test-renderer":  "19.1.0",
                            "tailwindcss":  "^3.4.10"
                        },
    "jest":  {
                 "testEnvironment":  "node",
                 "roots":  [
                               "\u003crootDir\u003e/__tests__"
                           ],
                 "testMatch":  [
                                   "**/*.test.ts"
                               ],
                 "setupFilesAfterEnv":  [
                                            "\u003crootDir\u003e/__tests__/jest.setup.ts"
                                        ],
                 "moduleNameMapper":  {
                                          "^react$":  "\u003crootDir\u003e/node_modules/react",
                                          "^react/(.*)$":  "\u003crootDir\u003e/node_modules/react/$1",
                                          "^react-native$":  "\u003crootDir\u003e/node_modules/react-native",
                                          "^react-native/(.*)$":  "\u003crootDir\u003e/node_modules/react-native/$1",
                                          "^@/(.*)$":  "\u003crootDir\u003e/$1",
                                          "^@traveling/shared$":  "\u003crootDir\u003e/../../packages/shared/src/index.ts"
                                      },
                 "transform":  {
                                   "^.+\\.[jt]sx?$":  [
                                                          "babel-jest",
                                                          {
                                                              "configFile":  false,
                                                              "babelrc":  false,
                                                              "caller":  {
                                                                             "name":  "metro",
                                                                             "bundler":  "metro",
                                                                             "platform":  "ios",
                                                                             "isDev":  false
                                                                         },
                                                              "presets":  [
                                                                              "babel-preset-expo"
                                                                          ]
                                                          }
                                                      ]
                               },
                 "transformIgnorePatterns":  [
                                                 "node_modules/(?!(?:jest-)?react-native|@react-native|@react-native-community|expo|expo-.*|@expo|@expo/.*|@expo-google-fonts/.*|@react-navigation/.*|@sentry/react-native|nativewind|react-native-css-interop|react-native-.*)"
                                             ],
                 "setupFiles":  [
                                    "\u003crootDir\u003e/__tests__/jest.globals.ts"
                                ]
             }
}