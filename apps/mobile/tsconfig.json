{
    "extends":  "expo/tsconfig.base",
    "compilerOptions":  {
                            "allowSyntheticDefaultImports":  true,
                            "baseUrl":  ".",
                            "jsx":  "react-native",
                            "moduleResolution":  "Bundler",
                            "noFallthroughCasesInSwitch":  true,
                            "noImplicitReturns":  true,
                            "noUncheckedIndexedAccess":  true,
                            "paths":  {
                                          "@/*":  [
                                                      "./*"
                                                  ],
                                          "react-native":  [
                                                               "./node_modules/react-native"
                                                           ],
                                          "react-native/*":  [
                                                                 "./node_modules/react-native/*"
                                                             ]
                                      },
                            "strict":  true,
                            "types":  [
                                          "nativewind/types"
                                      ]
                        },
    "include":  [
                    "**/*.ts",
                    "**/*.tsx",
                    ".expo/types/**/*.ts",
                    "expo-env.d.ts",
                    "nativewind-env.d.ts"
                ]
}