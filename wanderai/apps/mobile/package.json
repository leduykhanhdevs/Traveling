{
  "name": "@wanderai/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "build": "expo export --platform web",
    "dev": "expo start",
    "ios": "expo start --ios",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"services/**/*.{ts,tsx}\" \"stores/**/*.{ts,tsx}\" \"utils/**/*.{ts,tsx}\"",
    "start": "expo start",
    "start:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/start-lan.ps1",
    "start:tunnel": "expo start --tunnel -c",
    "test": "jest --config package.json --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.3.0",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.56.2",
    "@wanderai/shared": "1.0.0",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sms": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "lottie-react-native": "~7.3.1",
    "lucide-react-native": "^0.441.0",
    "nativewind": "4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.1.22",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-mmkv": "^2.12.2",
    "react-native-purchases": "^8.2.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "^7.0.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^56.0.14",
    "jest": "^29.7.0",
    "react-test-renderer": "^18.2.0",
    "tailwindcss": "^3.4.10"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@wanderai/shared$": "<rootDir>/../../packages/shared/src/index.ts"
    },
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    }
  }
}
