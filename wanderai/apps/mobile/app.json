{
  "expo": {
    "name": "WanderAI",
    "slug": "wanderai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "wanderai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wanderai.app",
      "associatedDomains": ["applinks:wanderai.app"],
      "infoPlist": {
        "NSCameraUsageDescription": "WanderAI uses the camera to translate menus and signs.",
        "NSLocationWhenInUseUsageDescription": "WanderAI uses your location to find nearby restaurants and attractions.",
        "NSMicrophoneUsageDescription": "WanderAI uses the microphone for voice translation.",
        "NSSpeechRecognitionUsageDescription": "WanderAI transcribes speech for translation."
      }
    },
    "android": {
      "package": "com.wanderai.app",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "13.4"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
