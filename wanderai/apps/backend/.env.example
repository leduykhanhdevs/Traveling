# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000

# Database and cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wanderai
REDIS_URL=redis://localhost:6379

# Authentication
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
SENTRY_DSN=

# AI and language services
OPENAI_API_KEY=
DEEPL_API_KEY=
GOOGLE_CLOUD_API_KEY=
GOOGLE_PLACES_API_KEY=

# Review and social aggregation
SERPAPI_KEY=
APIFY_API_KEY=
# Optional actor overrides. Defaults target public TikTok and Facebook search actors.
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-scraper
APIFY_FACEBOOK_ACTOR_ID=apify/facebook-pages-scraper

# Utilities
EXCHANGERATE_API_KEY=
OPENWEATHER_API_KEY=

# Monetization and notifications
REVENUECAT_API_KEY=
FCM_SERVER_KEY=
