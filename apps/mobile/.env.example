# Clerk publishable key from Clerk Dashboard > API Keys.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Public backend API URL reachable by Expo Go or the installed app.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google Maps SDK key for native map rendering and map-related client features.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Backward-compatible Google Maps key name used by older app configs.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# RevenueCat public iOS SDK key from RevenueCat project settings.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# RevenueCat public Android SDK key from RevenueCat project settings.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Optional PostHog host for product analytics.
EXPO_PUBLIC_POSTHOG_HOST=

# Optional PostHog project key for analytics events.
EXPO_PUBLIC_POSTHOG_KEY=

# Optional Sentry mobile DSN from Sentry project settings.
EXPO_PUBLIC_SENTRY_DSN=
