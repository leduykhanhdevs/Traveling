generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  clerkId             String          @unique
  email               String          @unique
  preferredLanguage   String          @default("en")
  dietaryRestrictions String[]        @default([])
  travelStyle         String          @default("local")
  spicyPreference     Int             @default(3)
  sweetPreference     Int             @default(3)
  savoryPreference    Int             @default(3)
  subscriptionTier    String          @default("free")
  nationality         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  budgets             Budget[]
  deviceTokens        DeviceToken[]
  emergencyContacts   EmergencyContact[]
  itineraries         Itinerary[]
  comments            Comment[]
  likes               Like[]
  posts               Post[]
  reviews             Review[]
  savedPlaces         SavedPlace[]
  searchHistory       SearchHistory[]
  activityLogs        ActivityLog[]
  viewedPlaces        ViewedPlace[]
}

model Budget {
  id          String       @id @default(cuid())
  userId      String
  tripName    String
  totalBudget Float
  currency    String
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       BudgetItem[]

  @@index([userId, createdAt])
}

model BudgetItem {
  id          String   @id @default(cuid())
  budgetId    String
  category    String
  amount      Float
  description String
  date        DateTime
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, date])
  @@index([category])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@index([token])
}

model EmergencyContact {
  id           String @id @default(cuid())
  userId       String
  name         String
  phone        String
  relationship String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  lat       Float
  lng       Float
  results   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  name      String
  address   String
  lat       Float
  lng       Float
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([userId, savedAt])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  placeId     String
  rating      Float
  text        String
  photos      String[] @default([])
  tags        String[] @default([])
  nationality String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId, createdAt])
  @@index([nationality, createdAt])
}

model Translation {
  id             String   @id @default(cuid())
  hash           String   @unique
  sourceText     String
  sourceLang     String
  targetLang     String
  translatedText String
  cachedAt       DateTime @default(now())

  @@index([sourceLang, targetLang])
}

model Itinerary {
  id          String   @id @default(cuid())
  userId      String
  destination String
  days        Int
  budgetRange String
  content     Json
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Post {
  id        String    @id @default(cuid())
  userId    String
  content   String
  imageUrl  String?
  placeId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]

  @@index([userId, createdAt])
  @@index([placeId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g. "search", "translate", "save_place", "create_post"
  details   Json?    // any additional structured log info
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ViewedPlace {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  name      String
  address   String
  lat       Float
  lng       Float
  emoji     String   @default("📍")
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([userId, viewedAt])
}
