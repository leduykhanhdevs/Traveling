# Node runtime. Use development, test, or production.
NODE_ENV=development

# Express port for the backend API.
PORT=4000

# Public backend URL used for generated links.
APP_URL=http://localhost:4000

# Comma-separated browser origins allowed in production. Native apps do not send an Origin header.
CORS_ALLOWED_ORIGINS=

# Pooled PostgreSQL connection used by the backend at runtime (Supabase pooler in production).
DATABASE_URL=

# Direct PostgreSQL connection used only by Prisma migrations (Supabase direct connection).
DIRECT_URL=

# Redis connection URL from your local Redis instance or managed Redis provider.
REDIS_URL=

# Clerk backend secret key from Clerk Dashboard > API Keys.
CLERK_SECRET_KEY=

# Optional Clerk webhook signing secret from Clerk Dashboard > Webhooks.
CLERK_WEBHOOK_SECRET=

# Optional Sentry backend DSN from Sentry project settings.
SENTRY_DSN=

# OpenAI API key for AI reasoning and itinerary/recommendation generation.
OPENAI_API_KEY=

# DeepL API key for primary text translation.
DEEPL_API_KEY=

# Google Cloud API key for Speech-to-Text, OCR, and translation fallback.
GOOGLE_CLOUD_API_KEY=

# Google Places API key for maps, places, details, and reverse geocoding.
GOOGLE_PLACES_API_KEY=

# SerpAPI key for Google Maps review aggregation.
SERPAPI_KEY=

# Apify API token for TikTok/Facebook public review aggregation.
APIFY_API_KEY=

# Optional alias supported by env validation when APIFY_API_KEY is not set.
APIFY_TOKEN=

# Optional Apify TikTok actor override. Defaults to clockworks/tiktok-scraper.
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-scraper

# Optional Apify Facebook actor override. Defaults to apify/facebook-pages-scraper.
APIFY_FACEBOOK_ACTOR_ID=apify/facebook-pages-scraper

# ExchangeRate API key for currency conversion utilities.
EXCHANGERATE_API_KEY=

# OpenWeather API key for destination weather utilities.
OPENWEATHER_API_KEY=

# RevenueCat secret API key for subscription entitlement checks.
REVENUECAT_API_KEY=

# SePay HMAC secret used to verify bank-transfer webhooks (minimum 32 characters).
SEPAY_WEBHOOK_SECRET=

# Independent HMAC secret used to sign budget and itinerary invitation tokens.
INVITE_TOKEN_SECRET=

# Optional Supabase Storage server configuration. Never expose the service key to mobile.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional product analytics configuration.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Apple universal-link identifiers. Supply the real Team ID before production release.
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=com.traveling.app

# Twilio server credentials used by SOS SMS delivery.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional legacy FCM server key. Expo push API is used by default.
FCM_SERVER_KEY=
