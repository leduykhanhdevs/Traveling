{
  "name": "@wanderai/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "build": "expo export --platform web",
    "dev": "expo start",
    "ios": "expo start --ios",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"services/**/*.{ts,tsx}\" \"stores/**/*.{ts,tsx}\" \"utils/**/*.{ts,tsx}\"",
    "start": "expo start",
    "start:lan": "powershell -ExecutionPolicy Bypass -File ./scripts/start-lan.ps1",
    "start:tunnel": "expo start --tunnel -c",
    "test": "jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.3.0",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@sentry/react-native": "~5.24.3",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.56.2",
    "@wanderai/shared": "1.0.0",
    "expo": "~51.0.39",
    "expo-av": "~14.0.7",
    "expo-blur": "~13.0.2",
    "expo-build-properties": "~0.12.5",
    "expo-camera": "~15.0.16",
    "expo-constants": "~16.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-haptics": "~13.0.1",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~6.3.1",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-print": "~13.0.1",
    "expo-router": "~3.5.24",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.1",
    "expo-sms": "~12.0.1",
    "expo-speech": "~12.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-web-browser": "~13.0.3",
    "lottie-react-native": "6.7.0",
    "lucide-react-native": "^0.441.0",
    "nativewind": "4.1.23",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-css-interop": "^0.1.22",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-maps": "1.14.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-purchases": "^8.2.4",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "^7.0.2",
    "@types/react": "~18.2.79",
    "jest": "^29.7.0",
    "react-test-renderer": "^18.2.0",
    "tailwindcss": "^3.4.10"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@wanderai/shared$": "<rootDir>/../../packages/shared/src/index.ts"
    },
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    }
  }
}
