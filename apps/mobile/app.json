{
  "expo": {
    "name": "Traveling",
    "slug": "traveling",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "traveling",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.traveling.app",
      "associatedDomains": [
        "applinks:traveling.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Traveling uses the camera to translate menus and signs.",
        "NSLocationWhenInUseUsageDescription": "Traveling uses your location to find nearby restaurants and attractions.",
        "NSMicrophoneUsageDescription": "Traveling uses the microphone for voice translation.",
        "NSSpeechRecognitionUsageDescription": "Traveling transcribes speech for translation.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.traveling.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f0f1a"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "11283d14-951d-4d7b-a9cc-86f6b5228f78"
      }
    }
  }
}
